# ─────────────────────────────────────────────────────────────────────────────
# LinkShrink — Environment Variables Template
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── MongoDB ───────────────────────────────────────────────────────────────────
# Get this from: Vercel Dashboard → Storage → MongoDB → Connect
MONGODB_URI="mongodb+srv://user:password@cluster.mongodb.net/?retryWrites=true&w=majority"

# ── NextAuth ──────────────────────────────────────────────────────────────────
# Generate a secret: openssl rand -base64 32
# In Vercel production, set NEXTAUTH_URL to your deployment URL.
NEXTAUTH_SECRET="your-secret-here-min-32-chars"
NEXTAUTH_URL=http://localhost:3000

# ── Public base URL ───────────────────────────────────────────────────────────
# Development : http://localhost:3000
# Production  : https://yourdomain.com
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# ─── MongoDB Indexes (run once in MongoDB Atlas or mongosh) ─────────────────
#
# db.links.createIndex({ short_code: 1 }, { unique: true })
# db.links.createIndex({ long_url: 1 })
# db.links.createIndex({ user_id: 1 })
# db.clicks.createIndex({ link_id: 1 })
# db.clicks.createIndex({ link_id: 1, timestamp: -1 })
# db.clicks.createIndex({ link_id: 1, visitor_hash: 1, timestamp: -1 })
# db.users.createIndex({ email: 1 }, { unique: true })
